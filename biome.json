{
  "$schema": "https://biomejs.dev/schemas/stable/schema.json",
  "formatter": {
    "indentStyle": "space"
  },
  "files": {
    "includes": [
      "**/*",
      "!**/build",
      "!!**/.vscode/extensions.json",
      "!!**/build",
      "!!**/dist",
      "!!**/node_modules",
      "!!**/out",
      "!!**/target",
      "!!**/mkdocs/site",
      "!!**/mkdocs/**/*.html",
      "!!**/*.svg"
    ]
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single"
    }
  },
  "overrides": [
    {
      "includes": ["*.test.ts", "**/*.test.ts"],
      "linter": {
        "rules": {
          "suspicious": {
            "noExplicitAny": "off"
          }
        }
      }
    },
    {
      "includes": [
        "**/build/**",
        ".turbo/**/*",
        "mkdocs/**/*.css",
        "mkdocs/**/*.html",
        "mkdocs/**/*.svg"
      ],
      "linter": {
        "enabled": false
      },
      "formatter": {
        "enabled": false
      },
      "javascript": {
        "assist": {
          "enabled": false
        }
      }
    }
  ]
}
